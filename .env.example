# ===========================
# FlowHR Environment Variables
# ===========================
# Copy this file to .env and fill in values

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowhr
DB_USERNAME=flowhr_user
DB_PASSWORD=change_me_strong_password

# --- JWT ---
JWT_SECRET=change_me_very_long_secret_key_at_least_256_bits_for_hs256
JWT_EXPIRATION_MS=86400000

# --- Spring Boot ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- Astro / Frontend ---
PUBLIC_API_URL=http://localhost:8080/api/v1
ASTRO_PORT=4321

# --- PDF (OpenPDF) ---
PDF_PAYSLIP_PASSWORD_PREFIX=FLOWHR_

# --- Docker Compose ---
POSTGRES_DB=${DB_NAME}
POSTGRES_USER=${DB_USERNAME}
POSTGRES_PASSWORD=${DB_PASSWORD}
