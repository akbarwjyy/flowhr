---
// app/analytics/index.astro — Analytics Center
import AppLayout from "../../../layouts/AppLayout.astro";
---

<AppLayout title="Analytics" activeMenu="analytics">
    <div class="analytics-page">
        <section class="hero-card">
            <div>
                <div class="eyebrow">Analytics Center</div>
                <h1>Ringkasan data HR, attendance, dan payroll</h1>
                <p>
                    Halaman ini menampilkan data yang diolah oleh backend modul analytics:
                    headcount, turnover, kehadiran, dan rekap payroll.
                </p>
            </div>
            <div class="hero-meta">
                <div class="meta-chip">
                    <span class="meta-label">Tahun berjalan</span>
                    <strong id="currentYearLabel">—</strong>
                </div>
                <div class="meta-chip">
                    <span class="meta-label">Status data</span>
                    <strong id="pageStatus">Memuat...</strong>
                </div>
            </div>
        </section>

        <section class="section-block">
            <div class="section-head">
                <div>
                    <h2>Executive Summary</h2>
                    <p>Data ringkas dari endpoint /analytics/dashboard</p>
                </div>
                <button id="refreshAllBtn" class="btn-outline btn-small">Refresh</button>
            </div>

            <div class="stats-grid" id="summaryGrid">
                <div class="stat-card loading">
                    <div class="stat-value">—</div>
                    <div class="stat-label">Memuat data</div>
                </div>
            </div>
        </section>

        <section class="section-block two-column">
            <div class="panel">
                <div class="section-head compact">
                    <div>
                        <h2>Headcount per Departemen</h2>
                        <p>Endpoint /analytics/headcount/by-department</p>
                    </div>
                </div>
                <div class="table-shell" id="departmentTable">
                    <div class="empty-state">Memuat data departemen...</div>
                </div>
            </div>

            <div class="panel">
                <div class="section-head compact">
                    <div>
                        <h2>Komposisi Karyawan</h2>
                        <p>Distribusi aktif, probation, resign, dan termination</p>
                    </div>
                </div>
                <div class="composition-list" id="compositionList"></div>
            </div>
        </section>

        <section class="section-block">
            <div class="section-head">
                <div>
                    <h2>Turnover</h2>
                    <p>Perbandingan karyawan baru dan keluar per bulan</p>
                </div>
                <div class="filter-row">
                    <label class="filter-label" for="turnoverYear">Tahun</label>
                    <input id="turnoverYear" type="number" min="2020" />
                    <button id="loadTurnoverBtn" class="btn-primary btn-small">Load</button>
                </div>
            </div>
            <div class="panel">
                <div class="bar-chart" id="turnoverChart">
                    <div class="empty-state">Memuat turnover...</div>
                </div>
            </div>
        </section>

        <section class="section-block">
            <div class="section-head">
                <div>
                    <h2>Attendance Report</h2>
                    <p>Rekap kehadiran harian per karyawan</p>
                </div>
                <div class="filter-row">
                    <label class="filter-label" for="attendanceYear">Tahun</label>
                    <input id="attendanceYear" type="number" min="2020" />
                    <label class="filter-label" for="attendanceMonth">Bulan</label>
                    <input id="attendanceMonth" type="number" min="1" max="12" />
                    <button id="loadAttendanceBtn" class="btn-primary btn-small">Load</button>
                </div>
            </div>
            <div class="panel">
                <div class="table-shell" id="attendanceTable">
                    <div class="empty-state">Memuat attendance report...</div>
                </div>
            </div>
        </section>

        <section class="section-block two-column">
            <div class="panel">
                <div class="section-head compact">
                    <div>
                        <h2>Payroll Summary</h2>
                        <p>Endpoint /analytics/payroll-summary</p>
                    </div>
                    <div class="filter-row">
                        <label class="filter-label" for="payrollYear">Tahun</label>
                        <input id="payrollYear" type="number" min="2020" />
                        <label class="filter-label" for="payrollMonth">Bulan</label>
                        <input id="payrollMonth" type="number" min="1" max="12" />
                        <button id="loadPayrollBtn" class="btn-primary btn-small">Load</button>
                    </div>
                </div>
                <div class="payroll-summary" id="payrollSummary">
                    <div class="empty-state">Memuat payroll summary...</div>
                </div>
            </div>

            <div class="panel">
                <div class="section-head compact">
                    <div>
                        <h2>Payroll per Departemen</h2>
                        <p>Endpoint /analytics/payroll-report</p>
                    </div>
                </div>
                <div class="table-shell" id="payrollTable">
                    <div class="empty-state">Memuat payroll report...</div>
                </div>
            </div>
        </section>
    </div>
</AppLayout>

<style>
    .analytics-page {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .hero-card,
    .panel,
    .stat-card {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
        border: 1px solid var(--border);
        border-radius: 0;
    }

    .hero-card {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        padding: 28px;
        border-left: 4px solid var(--primary);
    }

    .eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 10px;
    }

    .hero-card h1 {
        font-size: 28px;
        line-height: 1.1;
        margin-bottom: 10px;
    }

    .hero-card p,
    .section-head p {
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.5;
    }

    .hero-meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: flex-start;
    }

    .meta-chip {
        min-width: 160px;
        padding: 14px 16px;
        border: 1px solid var(--border);
        background: var(--surface);
    }

    .meta-label,
    .filter-label {
        display: block;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--text-muted);
        margin-bottom: 6px;
    }

    .meta-chip strong {
        font-size: 18px;
    }

    .section-block {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .section-head {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .section-head.compact {
        align-items: center;
    }

    .section-head h2 {
        font-size: 18px;
        margin-bottom: 4px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 14px;
    }

    .stat-card {
        padding: 18px;
        min-height: 104px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-muted);
    }

    .stat-value {
        font-size: 30px;
        font-weight: 800;
        line-height: 1;
        margin-top: 10px;
    }

    .stat-subtitle {
        font-size: 12px;
        color: var(--text-muted);
    }

    .two-column {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.95fr);
        gap: 16px;
    }

    .panel {
        padding: 20px;
    }

    .table-shell {
        overflow: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th,
    td {
        padding: 12px 10px;
        font-size: 13px;
        border-bottom: 1px solid var(--border);
        text-align: left;
        white-space: nowrap;
    }

    th {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        color: var(--text-muted);
    }

    tr:hover td {
        background: rgba(255, 255, 255, 0.02);
    }

    .filter-row {
        display: flex;
        align-items: end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-row input {
        width: 110px;
        padding: 10px 12px;
    }

    .btn-small {
        padding: 9px 14px;
        font-size: 13px;
    }

    .empty-state {
        padding: 18px;
        color: var(--text-muted);
        border: 1px dashed var(--border);
        background: rgba(255, 255, 255, 0.01);
    }

    .composition-list,
    .payroll-summary,
    .bar-chart {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .composition-row,
    .summary-row,
    .chart-row {
        display: grid;
        gap: 12px;
        grid-template-columns: 1.1fr auto;
        align-items: center;
    }

    .composition-row strong,
    .summary-row strong {
        display: block;
        font-size: 13px;
    }

    .composition-row span,
    .summary-row span {
        color: var(--text-muted);
        font-size: 12px;
    }

    .bar-track {
        height: 10px;
        width: 100%;
        background: var(--surface2);
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--primary), var(--accent));
    }

    .bar-meta,
    .chart-meta {
        display: flex;
        gap: 8px;
        align-items: baseline;
        justify-content: flex-end;
        color: var(--text-muted);
        font-size: 12px;
    }

    .chart-row {
        grid-template-columns: 90px minmax(0, 1fr) 120px;
    }

    .month-pill {
        padding: 8px 10px;
        border: 1px solid var(--border);
        background: var(--surface);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        color: var(--text);
    }

    .muted {
        color: var(--text-muted);
    }

    @media (max-width: 1100px) {
        .two-column {
            grid-template-columns: 1fr;
        }

        .hero-card {
            flex-direction: column;
        }
    }

    @media (max-width: 720px) {
        .hero-card,
        .panel {
            padding: 18px;
        }

        .hero-card h1 {
            font-size: 24px;
        }

        .chart-row {
            grid-template-columns: 70px minmax(0, 1fr);
        }

        .chart-meta {
            grid-column: 1 / -1;
            justify-content: flex-start;
        }
    }
</style>

<script>
    type Row = Record<string, any>;

    const API =
        (import.meta as { env?: { PUBLIC_API_URL?: string } }).env?.PUBLIC_API_URL ||
        "http://localhost:8080/api/v1";
    const token = localStorage.getItem("flowhr_token");
    const year: number = new Date().getFullYear();
    const month: number = new Date().getMonth() + 1;

    const monthNames = [
        "Jan",
        "Feb",
        "Mar",
        "Apr",
        "Mei",
        "Jun",
        "Jul",
        "Agu",
        "Sep",
        "Okt",
        "Nov",
        "Des",
    ];

    const numberFormatter = new Intl.NumberFormat("id-ID");
    const currencyFormatter = new Intl.NumberFormat("id-ID", {
        style: "currency",
        currency: "IDR",
        maximumFractionDigits: 0,
    });

    function formatNumber(value: unknown): string {
        const parsed = Number(value || 0);
        return numberFormatter.format(Number.isFinite(parsed) ? parsed : 0);
    }

    function formatCurrency(value: unknown): string {
        const parsed = Number(value || 0);
        return currencyFormatter.format(Number.isFinite(parsed) ? parsed : 0);
    }

    function formatMonth(value: unknown): string {
        const index = Math.max(1, Math.min(12, Number(value || 1))) - 1;
        return monthNames[index] || "-";
    }

    function setText(id: string, value: string): void {
        const node = document.getElementById(id);
        if (node) node.textContent = value;
    }

    function setHTML(id: string, value: string): void {
        const node = document.getElementById(id);
        if (node) node.innerHTML = value;
    }

    function setInputValue(id: string, value: number): void {
        const node = document.getElementById(id) as HTMLInputElement | null;
        if (node) node.value = String(value);
    }

    function getInputValue(id: string, fallback: number): number {
        const node = document.getElementById(id) as HTMLInputElement | null;
        return Number(node?.value || fallback);
    }

    function setStatus(text: string): void {
        setText("pageStatus", text);
    }

    async function fetchJson(path: string): Promise<any> {
        const res = await fetch(`${API}${path}`, {
            headers: { Authorization: `Bearer ${token}` },
        });
        const json = await res.json();
        if (!json.success) {
            throw new Error(json.message || "Gagal memuat data");
        }
        return json.data;
    }

    function renderSummary(data: Row): void {
        const items = [
            { label: "Aktif", value: data.active_count || 0, subtitle: "Karyawan aktif" },
            { label: "Probation", value: data.probation_count || 0, subtitle: "Masa percobaan" },
            { label: "Resigned", value: data.resigned_count || 0, subtitle: "Keluar sukarela" },
            { label: "Terminated", value: data.terminated_count || 0, subtitle: "PHK / terminasi" },
            { label: "Laki-laki", value: data.male_count || 0, subtitle: "Komposisi gender" },
            { label: "Perempuan", value: data.female_count || 0, subtitle: "Komposisi gender" },
            { label: "Usia Perusahaan", value: `${data.company_age_years || 0} th`, subtitle: "Sejak join tertua" },
        ];

        const grid = document.getElementById("summaryGrid");
        if (!grid) return;

        grid.innerHTML = items
            .map(
                (item, index) => `
                    <div class="stat-card" style="border-top: 3px solid ${[
                        "var(--primary)",
                        "var(--accent)",
                        "var(--warning)",
                        "var(--purple)",
                        "#10b981",
                        "#ec4899",
                        "#f8fafc",
                    ][index]};">
                        <div class="stat-label">${item.label}</div>
                        <div class="stat-value">${item.value}</div>
                        <div class="stat-subtitle">${item.subtitle}</div>
                    </div>
                `,
            )
            .join("");
    }

    function renderDepartmentTable(rows: Row[]): void {
        const body = rows
            .map(
                (row: Row) => `
                    <tr>
                        <td>${row.department || "-"}</td>
                        <td style="font-weight:700; color:#F8FAFC;">${formatNumber(row.employee_count)}</td>
                        <td>${formatNumber(row.male_count)}</td>
                        <td>${formatNumber(row.female_count)}</td>
                    </tr>
                `,
            )
            .join("");

        setHTML("departmentTable", `
            <table>
                <thead>
                    <tr>
                        <th>Departemen</th>
                        <th>Total</th>
                        <th>Laki-laki</th>
                        <th>Perempuan</th>
                    </tr>
                </thead>
                <tbody>${body || '<tr><td colspan="4" class="muted">Tidak ada data departemen.</td></tr>'}</tbody>
            </table>
        `);
    }

    function renderComposition(data: Row): void {
        const items = [
            { label: "Karyawan Aktif", value: data.active_count || 0 },
            { label: "Masa Percobaan", value: data.probation_count || 0 },
            { label: "Resigned", value: data.resigned_count || 0 },
            { label: "Terminated", value: data.terminated_count || 0 },
            { label: "Laki-laki", value: data.male_count || 0 },
            { label: "Perempuan", value: data.female_count || 0 },
        ];

        const max = Math.max(...items.map((item) => Number(item.value || 0)), 1);
        setHTML("compositionList", items
            .map(
                (item) => `
                    <div>
                        <div class="composition-row">
                            <div>
                                <strong>${item.label}</strong>
                                <span>${formatNumber(item.value)} karyawan</span>
                            </div>
                            <div class="bar-meta">${Math.round((Number(item.value || 0) / max) * 100)}%</div>
                        </div>
                        <div class="bar-track" aria-hidden="true">
                            <div class="bar-fill" style="width: ${Math.round((Number(item.value || 0) / max) * 100)}%;"></div>
                        </div>
                    </div>
                `,
            )
            .join(""));
    }

    function renderTurnover(rows: Row[], selectedYear: number): void {
        const normalized = Array.from({ length: 12 }, (_, index) => {
            const row = rows.find((item: Row) => Number(item.month) === index + 1) || {};
            return {
                month: index + 1,
                new_hires: Number(row.new_hires || 0),
                departures: Number(row.departures || 0),
            };
        });
        const max = Math.max(
            ...normalized.flatMap((item) => [item.new_hires, item.departures]),
            1,
        );

        setHTML("turnoverChart", normalized
            .map(
                (item) => `
                    <div class="chart-row">
                        <div class="month-pill">${formatMonth(item.month)}</div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width: ${Math.round((item.new_hires / max) * 100)}%;"></div>
                        </div>
                        <div class="chart-meta">
                            <span style="color: #d4ff00; font-weight:700;">Masuk ${formatNumber(item.new_hires)}</span>
                            <span style="color: #f59e0b; font-weight:700;">Keluar ${formatNumber(item.departures)}</span>
                        </div>
                    </div>
                `,
            )
            .join("") || `<div class="empty-state">Tidak ada data turnover untuk ${selectedYear}.</div>`);
    }

    function renderAttendance(rows: Row[]): void {
        const body = rows
            .map(
                (row: Row) => `
                    <tr>
                        <td>${row.nip || "-"}</td>
                        <td>${row.first_name || "-"} ${row.last_name || ""}</td>
                        <td>${row.department || "-"}</td>
                        <td>${formatNumber(row.total_days)}</td>
                        <td>${formatNumber(row.present_days)}</td>
                        <td>${formatNumber(row.late_days)}</td>
                        <td>${formatNumber(row.absence_days)}</td>
                        <td>${formatNumber(row.total_work_minutes)}</td>
                        <td>${formatNumber(row.total_overtime_minutes)}</td>
                    </tr>
                `,
            )
            .join("");

        setHTML("attendanceTable", `
            <table>
                <thead>
                    <tr>
                        <th>NIP</th>
                        <th>Nama</th>
                        <th>Departemen</th>
                        <th>Total Hari</th>
                        <th>Hadir</th>
                        <th>Terlambat</th>
                        <th>Absen</th>
                        <th>Work Minutes</th>
                        <th>Overtime</th>
                    </tr>
                </thead>
                <tbody>${body || '<tr><td colspan="9" class="muted">Tidak ada data attendance.</td></tr>'}</tbody>
            </table>
        `);
    }

    function renderPayrollSummary(data: Row): void {
        const items = [
            { label: "Total Karyawan", value: data.total_employees || 0 },
            { label: "Gross Salary", value: formatCurrency(data.total_gross_salary || 0) },
            { label: "Total Deduction", value: formatCurrency(data.total_deduction || 0) },
            { label: "Net Salary", value: formatCurrency(data.total_net_salary || 0) },
            { label: "Total PPh21", value: formatCurrency(data.total_pph21 || 0) },
            { label: "BPJS Kesehatan", value: formatCurrency(data.total_bpjs_kes || 0) },
            { label: "BPJS Ketenagakerjaan", value: formatCurrency(data.total_bpjs_tk || 0) },
        ];

        setHTML("payrollSummary", items
            .map(
                (item) => `
                    <div class="summary-row">
                        <div>
                            <strong>${item.label}</strong>
                            <span>${item.value}</span>
                        </div>
                    </div>
                `,
            )
            .join(""));
    }

    function renderPayrollTable(rows: Row[]): void {
        const body = rows
            .map(
                (row: Row) => `
                    <tr>
                        <td>${row.department || "-"}</td>
                        <td>${formatNumber(row.employee_count)}</td>
                        <td>${formatCurrency(row.total_base_salary || 0)}</td>
                        <td>${formatCurrency(row.total_meal_allowance || 0)}</td>
                        <td>${formatCurrency(row.total_reimbursement || 0)}</td>
                        <td>${formatCurrency(row.total_gross_salary || 0)}</td>
                        <td>${formatCurrency(row.total_deduction || 0)}</td>
                        <td>${formatCurrency(row.total_net_salary || 0)}</td>
                    </tr>
                `,
            )
            .join("");

        setHTML("payrollTable", `
            <table>
                <thead>
                    <tr>
                        <th>Departemen</th>
                        <th>Karyawan</th>
                        <th>Base Salary</th>
                        <th>Meal Allowance</th>
                        <th>Reimbursement</th>
                        <th>Gross</th>
                        <th>Deduction</th>
                        <th>Net</th>
                    </tr>
                </thead>
                <tbody>${body || '<tr><td colspan="8" class="muted">Tidak ada data payroll.</td></tr>'}</tbody>
            </table>
        `);
    }

    async function loadSummary() {
        const data = await fetchJson("/analytics/dashboard");
        renderSummary(data);
        renderComposition(data);
        setText("currentYearLabel", String(year));
    }

    async function loadDepartmentData() {
        const rows = await fetchJson("/analytics/headcount/by-department");
        renderDepartmentTable(rows);
    }

    async function loadTurnoverData(selectedYear: number): Promise<void> {
        const rows = await fetchJson(`/analytics/turnover?year=${selectedYear}`);
        renderTurnover(rows, selectedYear);
    }

    async function loadAttendanceData(selectedYear: number, selectedMonth: number): Promise<void> {
        const rows = await fetchJson(
            `/analytics/attendance-report?year=${selectedYear}&month=${selectedMonth}`,
        );
        renderAttendance(rows);
    }

    async function loadPayrollData(selectedYear: number, selectedMonth: number): Promise<void> {
        const summary = await fetchJson(
            `/analytics/payroll-summary?year=${selectedYear}&month=${selectedMonth}`,
        );
        const rows = await fetchJson(
            `/analytics/payroll-report?year=${selectedYear}&month=${selectedMonth}`,
        );
        renderPayrollSummary(summary);
        renderPayrollTable(rows);
    }

    async function loadAll() {
        setStatus("Memuat...");
        try {
            await Promise.all([
                loadSummary(),
                loadDepartmentData(),
                loadTurnoverData(year),
                loadAttendanceData(year, month),
                loadPayrollData(year, month),
            ]);
            setStatus("Siap");
        } catch (error) {
            console.error("Analytics load error:", error);
            setStatus("Gagal memuat data");
            setHTML(
                "summaryGrid",
                '<div class="empty-state">Gagal memuat analytics. Pastikan token valid dan backend berjalan.</div>',
            );
        }
    }

    setInputValue("turnoverYear", year);
    setInputValue("attendanceYear", year);
    setInputValue("attendanceMonth", month);
    setInputValue("payrollYear", year);
    setInputValue("payrollMonth", month);

    const refreshAllBtn = document.getElementById("refreshAllBtn") as HTMLButtonElement | null;
    if (refreshAllBtn) refreshAllBtn.addEventListener("click", loadAll);

    const loadTurnoverBtn = document.getElementById("loadTurnoverBtn") as HTMLButtonElement | null;
    if (loadTurnoverBtn) {
        loadTurnoverBtn.addEventListener("click", () => {
            loadTurnoverData(getInputValue("turnoverYear", year));
        });
    }

    const loadAttendanceBtn = document.getElementById("loadAttendanceBtn") as HTMLButtonElement | null;
    if (loadAttendanceBtn) {
        loadAttendanceBtn.addEventListener("click", () => {
            loadAttendanceData(
                getInputValue("attendanceYear", year),
                getInputValue("attendanceMonth", month),
            );
        });
    }

    const loadPayrollBtn = document.getElementById("loadPayrollBtn") as HTMLButtonElement | null;
    if (loadPayrollBtn) {
        loadPayrollBtn.addEventListener("click", () => {
            loadPayrollData(
                getInputValue("payrollYear", year),
                getInputValue("payrollMonth", month),
            );
        });
    }

    loadAll();
</script>