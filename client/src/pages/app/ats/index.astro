---
// app/ats/index.astro — Rekrutmen ATS dengan KanbanBoard React Island
import AppLayout from "../../../layouts/AppLayout.astro";
import KanbanBoard from "../../../components/islands/KanbanBoard";
---

<AppLayout title="Rekrutmen (ATS)" activeMenu="ats">
    <div style="margin-bottom: 24px;">
        <!-- Job selector -->
        <div
            style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;"
        >
            <label style="font-size: 14px; color: #94A3B8;"
                >Pilih Lowongan:</label
            >
            <select
                id="jobSelect"
                style="background:var(--surface); border:1px solid var(--border); color:#F1F5F9; padding:8px 14px; border-radius: 0px; font-size:14px; font-family:inherit;"
            >
                <option value="">Memuat...</option>
            </select>
        </div>

        <!-- KanbanBoard -->
        <div id="kanbanWrapper" style="display:none;">
            <KanbanBoard jobId={0} client:only="react" />
        </div>
        <div
            id="kanbanPlaceholder"
            style="background:var(--surface); border:1px solid var(--border); border-radius: 0px; padding:48px; text-align:center; color:#64748B;"
        >
            Pilih lowongan untuk melihat pipeline pelamar
        </div>
    </div>
</AppLayout>

<script>
    const API =
        (import.meta as any).env?.PUBLIC_API_URL ||
        "http://localhost:8080/api/v1";
    const token = localStorage.getItem("flowhr_token");

    async function loadJobs() {
        try {
            const res = await fetch(`${API}/ats/jobs`, {
                headers: { Authorization: `Bearer ${token}` },
            });
            const data = await res.json();
            const select = document.getElementById(
                "jobSelect",
            ) as HTMLSelectElement;
            if (!data.success || !data.data.length) {
                select.innerHTML =
                    '<option value="">Tidak ada lowongan</option>';
                return;
            }
            select.innerHTML =
                '<option value="">Pilih lowongan...</option>' +
                data.data
                    .map(
                        (j: any) =>
                            `<option value="${j.id}">${j.title} (${j.status})</option>`,
                    )
                    .join("");
        } catch {}
    }

    loadJobs();
</script>
