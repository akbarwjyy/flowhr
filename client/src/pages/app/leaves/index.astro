---
// app/leaves/index.astro — Halaman Cuti (menggunakan React Island LeaveForm)
import AppLayout from "../../../layouts/AppLayout.astro";
import LeaveForm from "../../../components/islands/LeaveForm";
---

<AppLayout title="Manajemen Cuti" activeMenu="leaves">
    <div
        style="display: grid; grid-template-columns: 1fr 380px; gap: 24px; align-items: start;"
    >
        <!-- Riwayat cuti -->
        <div>
            <div
                style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;"
            >
                <h2 style="font-size: 16px; font-weight: 600;">Riwayat Cuti</h2>
                <div
                    id="quotaBadge"
                    style="background: var(--surface); border: 1px solid var(--border); border-radius: 0px; padding: 6px 14px; font-size: 13px; color: #94A3B8;"
                >
                    Sisa Cuti Tahunan: <span
                        id="quotaVal"
                        style="color: #F1F5F9; font-weight: 600;">—</span
                    > hari
                </div>
            </div>
            <div
                id="leaveList"
                style="display: flex; flex-direction: column; gap: 12px;"
            >
                <div style="color: #64748B; padding: 20px; text-align: center;">
                    Memuat riwayat...
                </div>
            </div>
        </div>

        <!-- Form pengajuan (React Island) -->
        <div
            style="background: var(--surface); border: 1px solid var(--border); border-radius: 0px; padding: 24px; position: sticky; top: 80px;"
        >
            <h3 style="font-size: 15px; font-weight: 600; margin-bottom: 16px;">
                Ajukan Cuti Baru
            </h3>
            <LeaveForm client:load />
        </div>
    </div>
</AppLayout>

<style>
    .leave-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 16px;
    }
    .leave-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
    }
    .leave-type {
        font-size: 13px;
        font-weight: 600;
        color: #f1f5f9;
    }
    .leave-dates {
        font-size: 12px;
        color: #94a3b8;
        margin-bottom: 4px;
    }
    .leave-reason {
        font-size: 12px;
        color: #64748b;
    }
    .status-badge {
        padding: 3px 10px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<script>
    const API =
        (import.meta as any).env?.PUBLIC_API_URL ||
        "http://localhost:8080/api/v1";
    const token = localStorage.getItem("flowhr_token");
    const headers = { Authorization: `Bearer ${token}` };

    const STATUS_COLORS: Record<string, string> = {
        PENDING: "#F59E0B",
        APPROVED_MANAGER: "#06B6D4",
        APPROVED_HR: "#10B981",
        REJECTED: "#EF4444",
        CANCELLED: "#64748B",
    };
    const STATUS_LABELS: Record<string, string> = {
        PENDING: "Menunggu",
        APPROVED_MANAGER: "Disetujui Manajer",
        APPROVED_HR: "Disetujui HR",
        REJECTED: "Ditolak",
        CANCELLED: "Dibatalkan",
    };

    async function loadLeaves() {
        try {
            const res = await fetch(`${API}/leaves/my`, { headers });
            const data = await res.json();
            const list = document.getElementById("leaveList")!;
            if (!data.success || !data.data.length) {
                list.innerHTML =
                    '<div style="color: #64748B; padding: 20px; text-align: center;">Belum ada riwayat cuti</div>';
                return;
            }
            list.innerHTML = data.data
                .map(
                    (l: any) => `
        <div class="leave-card">
          <div class="leave-header">
            <div class="leave-type">${l.leave_type} — ${l.total_days} hari</div>
            <span class="status-badge" style="background: ${STATUS_COLORS[l.status] || "var(--border)"}22; color: ${STATUS_COLORS[l.status] || "#94A3B8"};">
              ${STATUS_LABELS[l.status] || l.status}
            </span>
          </div>
          <div class="leave-dates"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:text-bottom;margin-right:4px;"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg> ${l.start_date?.split("T")[0]} s.d. ${l.end_date?.split("T")[0]}</div>
          <div class="leave-reason">${l.reason}</div>
        </div>
      `,
                )
                .join("");
        } catch {}
    }

    async function loadQuota() {
        try {
            const res = await fetch(`${API}/leaves/my/quota?type=ANNUAL`, {
                headers,
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById("quotaVal")!.textContent =
                    data.data.remaining_days;
            }
        } catch {}
    }

    loadLeaves();
    loadQuota();

    // Refresh saat LeaveForm berhasil submit
    window.addEventListener("leaveSubmitted", () => {
        loadLeaves();
        loadQuota();
    });
</script>
