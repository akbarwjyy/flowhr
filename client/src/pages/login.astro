---
// client/src/pages/login.astro
import "../styles/global.css";

const API = import.meta.env.PUBLIC_API_URL || "http://localhost:8080/api/v1";
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="FlowHR — HR Management System" />
        <title>Login | FlowHR</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap"
            rel="stylesheet"
        />
        <style>
            body {
                background-image:
                    linear-gradient(var(--grid) 1px, transparent 1px),
                    linear-gradient(90deg, var(--grid) 1px, transparent 1px);
                background-size: 80px 80px;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 24px;
                position: relative;
            }

            /* Floating decorative elements */
            .float-shape {
                position: absolute;
                z-index: -1;
            }
            .shape-1 {
                left: 10%;
                top: 20%;
                width: 40px;
                height: 40px;
                background: var(--cyan);
                border-radius: 50%;
                opacity: 0.8;
            }
            .shape-2 {
                right: 15%;
                top: 30%;
                width: 48px;
                height: 48px;
                background: var(--pink);
                border-radius: 50%;
                clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
                opacity: 0.8;
            }
            .shape-3 {
                left: 20%;
                bottom: 20%;
                width: 32px;
                height: 32px;
                background: var(--lime);
                border-radius: 50%;
                opacity: 0.8;
            }

            .card {
                background: var(--dark);
                border: 1px solid var(--border);
                border-radius: 0px; /* Sharp corners like the image */
                padding: 48px;
                width: 100%;
                max-width: 420px;
                position: relative;
            }

            /* Optional top border accent */
            .card::before {
                content: "";
                position: absolute;
                top: -1px;
                left: -1px;
                right: -1px;
                height: 2px;
                background: linear-gradient(
                    90deg,
                    var(--lime),
                    var(--cyan),
                    var(--pink)
                );
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 40px;
            }

            .logo-icon {
                display: flex;
                align-items: flex-end;
                gap: 2px;
                height: 28px;
            }
            .logo-icon div {
                width: 7px;
                background: white;
            }
            .logo-icon div:nth-child(1) {
                height: 14px;
                background: var(--pink);
            }
            .logo-icon div:nth-child(2) {
                height: 21px;
                background: var(--cyan);
            }
            .logo-icon div:nth-child(3) {
                height: 28px;
                background: white;
            }

            .logo-text {
                font-size: 28px;
                font-weight: 800;
                letter-spacing: -0.5px;
            }

            h1 {
                font-size: 24px;
                font-weight: 800;
                margin-bottom: 8px;
                letter-spacing: -0.5px;
            }

            p {
                color: var(--text-muted);
                font-size: 14px;
                margin-bottom: 32px;
                line-height: 1.5;
            }

            .form-group {
                margin-bottom: 24px;
            }

            .error-msg {
                background: rgba(236, 72, 153, 0.1); /* Pink tint */
                border: 1px solid rgba(236, 72, 153, 0.3);
                border-radius: 4px;
                padding: 12px;
                font-size: 13px;
                color: var(--pink);
                margin-top: 20px;
                display: none;
            }

            .back-link {
                display: inline-block;
                margin-top: 24px;
                font-size: 13px;
                color: var(--text-muted);
                text-decoration: none;
                transition: color 0.2s;
            }
            .back-link:hover {
                color: var(--text-main);
            }
        </style>
    </head>
    <body>
        <div class="float-shape shape-1"></div>
        <div class="float-shape shape-2"></div>
        <div class="float-shape shape-3"></div>

        <div class="card">
            <div class="logo">
                <div class="logo-icon">
                    <div></div><div></div><div></div>
                </div>
                <div class="logo-text">FLOW</div>
            </div>

            <h1>Selamat Datang</h1>
            <p>Silakan masuk ke portal manajemen SDM Anda.</p>

            <form id="loginForm">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input
                        id="username"
                        name="username"
                        type="text"
                        placeholder="Contoh: superadmin"
                        autocomplete="username"
                        required
                    />
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input
                        id="password"
                        name="password"
                        type="password"
                        placeholder="••••••••"
                        autocomplete="current-password"
                        required
                    />
                </div>
                <button
                    type="submit"
                    id="submitBtn"
                    class="btn-primary"
                    style="width: 100%; margin-top: 8px;"
                    >Masuk ke Sistem</button
                >
                <div class="error-msg" id="errorMsg"></div>
            </form>

            <a href="/careers" class="back-link"
                >&larr; Kembali ke halaman karir</a
            >
        </div>

        <script define:vars={{ apiUrl: API }}>
            if (localStorage.getItem("flowhr_token")) {
                window.location.href = "/app/dashboard";
            }

            const API_BASE = apiUrl || "http://localhost:8080/api/v1";

            document
                .getElementById("loginForm")
                .addEventListener("submit", async (e) => {
                    e.preventDefault();
                    const btn = document.getElementById("submitBtn");
                    const errDiv = document.getElementById("errorMsg");

                    errDiv.style.display = "none";
                    btn.disabled = true;
                    btn.textContent = "Sedang verifikasi...";

                    const username = document.getElementById("username").value;
                    const password = document.getElementById("password").value;

                    try {
                        const res = await fetch(`${API_BASE}/auth/login`, {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ username, password }),
                        });
                        const data = await res.json();
                        if (!data.success) throw new Error(data.message);

                        localStorage.setItem("flowhr_token", data.data.token);
                        localStorage.setItem(
                            "flowhr_user",
                            JSON.stringify(data.data),
                        );

                        window.location.href = "/app/dashboard";
                    } catch (err) {
                        errDiv.textContent = err.message || "Login gagal";
                        errDiv.style.display = "block";
                        btn.disabled = false;
                        btn.textContent = "Masuk ke Sistem";
                    }
                });
        </script>
    </body>
</html>
